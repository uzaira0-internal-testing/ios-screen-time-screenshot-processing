# =============================================================================
# Backend Dockerfile - Development (standalone app, no monorepo required)
# =============================================================================
# Python 3.12 with FastAPI, Tesseract OCR, and async PostgreSQL support
#
# Build context: app root (..)
# docker build -f docker/backend/Dockerfile.dev .

FROM python:3.12-slim

# Install system dependencies including Tesseract OCR
RUN apt-get update && apt-get install -y --no-install-recommends \
    tesseract-ocr \
    libtesseract-dev \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgomp1 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Install uv for faster package installation
RUN pip install --no-cache-dir uv

# Copy shared monorepo packages (vendored in docker/backend/packages/)
COPY docker/backend/packages/global-pass-honor-username-auth /app/packages/global-pass-honor-username-auth
COPY docker/backend/packages/fastapi-errors /app/packages/fastapi-errors
COPY docker/backend/packages/fastapi-logging /app/packages/fastapi-logging
COPY docker/backend/packages/fastapi-ratelimit /app/packages/fastapi-ratelimit
COPY docker/backend/packages/db-toolkit /app/packages/db-toolkit
COPY docker/backend/packages/fastapi-pagination /app/packages/fastapi-pagination
COPY docker/backend/packages/fastapi-files /app/packages/fastapi-files
COPY docker/backend/packages/fastapi-tasks /app/packages/fastapi-tasks

# Copy app dependency files
COPY pyproject.toml ./

# Copy preprocessing packages (local dependencies -> /opt/packages/ where pyproject.toml expects them)
COPY docker/backend/packages/ios-device-detector /opt/packages/ios-device-detector
COPY docker/backend/packages/ipad-screenshot-cropper /opt/packages/ipad-screenshot-cropper
COPY docker/backend/packages/phi-detector-remover /opt/packages/phi-detector-remover

# Create minimal src structure needed for editable install
RUN mkdir -p src/screenshot_processor && \
    touch src/screenshot_processor/__init__.py

# Install shared packages by path (before app dependencies)
RUN uv pip install --system --no-cache-dir \
    /app/packages/global-pass-honor-username-auth \
    /app/packages/fastapi-errors \
    /app/packages/fastapi-logging \
    /app/packages/fastapi-ratelimit \
    /app/packages/db-toolkit \
    /app/packages/fastapi-pagination \
    /app/packages/fastapi-files \
    /app/packages/fastapi-tasks

# Install app dependencies (cached unless pyproject.toml changes)
RUN uv pip install --system --no-cache-dir -e ".[web,preprocessing]" alembic

# Copy application source code
COPY src/ ./src/
COPY alembic/ ./alembic/
COPY alembic.ini ./

# Create necessary directories
RUN mkdir -p /app/db /app/output /app/debug /app/uploads

# Create non-root user and set ownership
RUN useradd --create-home --shell /bin/bash appuser && \
    chown -R appuser:appuser /app
USER appuser

# Expose port
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Copy and set up entrypoint script
COPY docker/backend/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Default command - entrypoint handles migrations automatically
CMD ["/entrypoint.sh"]
